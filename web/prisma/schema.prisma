// Schema canónico de team22.
// Local: Postgres con pgvector vía Docker (`docker compose up`).
// Prod: Supabase Postgres (con extensión `vector` habilitada en el dashboard).
// El cliente Prisma es el mismo para los dos — solo cambia DATABASE_URL.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// La datasource URL vive en `prisma.config.ts` (cambio breaking de Prisma 7).
datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// =============================================================
// Enums
// =============================================================

enum Action {
  BLOCK
  REDACT
  WARN
  LOG
}

enum PolicyLayer {
  regex
  pattern
  nl
}

enum PolicySource {
  seed
  admin
  ai_suggestor     @map("ai-suggestor")
  google_workspace @map("google-workspace")
}

enum Severity {
  low
  medium
  high
}

/// Categorías canónicas de policies. Sincronizado con `seeds/`.
/// Si se agrega un valor nuevo, requiere migración.
enum PolicyDomain {
  credentials
  pii
  internal_paths
  business_policy
  code
}

/// Rol de un member dentro de una org.
///   - admin → humano que se loguea al back-office. Edita policies,
///             ve events/suggestions/dashboards de toda la org.
///   - dev   → entidad sin UI propia. Existe para atribuir interactions
///             del proxy a un dev concreto (vía API key del proxy,
///             post-hack). Sus "permisos" se materializan en el
///             comportamiento del proxy, no en una pantalla.
enum MemberRole {
  admin
  dev
}

enum SuggestionStatus {
  pending
  accepted
  rejected
}

// =============================================================
// Models
// =============================================================

/// Tenant raíz. Multi-tenancy es goal: para el hack se usa la org `demo`
/// hardcodeada via DEMO_ORG_ID, pero las queries ya filtran por org_id.
model Organization {
  id                String   @id // ej. 'demo', 'acme'
  name              String
  upstreamApiKeyRef String?  @map("upstream_api_key_ref") // formato "env:<VAR>" o "vault:<uuid>" — nunca la key cruda
  createdAt         DateTime @default(now()) @map("created_at")

  policies        Policy[]
  interactions    Interaction[]
  members         Member[]
  ruleSuggestions RuleSuggestion[]

  @@map("organizations")
}

/// Reglas que configura el admin (o el AI Suggestor en futuro).
/// El campo `layer` discrimina cómo se evalúa la regla en el proxy:
///   - regex   → matcher literal con `pattern`
///   - pattern → matcher de filename/path con `match_config`
///   - nl      → vector similarity contra `embedding`, después Haiku judge
model Policy {
  id            String                       @id @default(uuid()) @db.Uuid
  orgId         String                       @default("demo") @map("org_id")
  slug          String
  domain        PolicyDomain // categoría canónica — ver enum PolicyDomain
  layer         PolicyLayer
  rule          String // texto NL (si layer='nl') o descripción humana de la regla
  pattern       String? // regex literal si layer='regex'
  matchConfig   Json?                        @map("match_config") // params si layer='pattern' (ej. {extensions:['.env','.pem']})
  defaultAction Action                       @map("default_action")
  severity      Severity                     @default(medium)
  embedding     Unsupported("vector(1536)")? // solo si layer='nl'
  source        PolicySource                 @default(seed)
  isActive      Boolean                      @default(true) @map("is_active")
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, slug])
  @@index([orgId, layer])
  @@map("policies")
}

/// Cada request de Claude Code que pasa por el proxy genera una fila acá.
/// El `prompt` se persiste **redactado** (las regex de credenciales corren
/// antes de escribir, sin importar si la action final fue LOG).
model Interaction {
  id             String                       @id @default(uuid()) @db.Uuid
  traceId        String                       @unique @map("trace_id")
  orgId          String                       @default("demo") @map("org_id")
  userId         String?                      @map("user_id") @db.Uuid // members.id (mismo UUID que auth.users.id cuando integremos Supabase Auth real)
  requestModel   String                       @map("request_model")
  prompt         String // SIEMPRE redactado antes de persistir
  action         Action
  reason         String
  policyHits     Json                         @default("[]") @map("policy_hits") // [{layer, policyId, slug, score?}]
  latencyTotalMs Int                          @map("latency_total_ms")
  latencyByLayer Json                         @default("{}") @map("latency_by_layer") // {regex, pattern, haiku, upstream}
  upstreamStatus Int?                         @map("upstream_status") // null si BLOCK (no hay upstream)
  embedding      Unsupported("vector(1536)")? // poblado por el proxy o backfill del Suggestor
  createdAt      DateTime                     @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  // Composite que cubre el dashboard (`/api/admin/metrics` y `/admin/events?action=...`).
  @@index([orgId, action, createdAt(sort: Desc)])
  @@map("interactions")
}

/// Identidades dentro de una org. Sólo los `admin` se loguean al back-office
/// (auth mock con magic link + código `123456` para el hack). Los `dev`
/// no tienen UI propia; existen como entidad para atribuir interactions
/// del proxy cuando emitamos API keys del proxy (post-hack).
/// Cuando integremos Supabase Auth real, `members.id` se mapea 1:1 a
/// `auth.users.id`.
model Member {
  id        String     @id @default(uuid()) @db.Uuid
  orgId     String     @default("demo") @map("org_id")
  email     String
  role      MemberRole @default(admin)
  createdAt DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, email])
  @@map("members")
}

/// Cola del AI Suggestor (Layer 4). Cada fila es una propuesta de regla
/// nueva derivada de `interactions`. El admin la acepta / rechaza / edita
/// desde `/admin/suggestions`. Aceptar promueve la sugerencia a una fila
/// real en `policies` con `source = ai-suggestor`.
model RuleSuggestion {
  id                  String           @id @default(uuid()) @db.Uuid
  orgId               String           @default("demo") @map("org_id")
  proposedSlug        String           @map("proposed_slug")
  proposedDomain      PolicyDomain     @map("proposed_domain")
  proposedLayer       PolicyLayer      @map("proposed_layer")
  proposedRule        String           @map("proposed_rule")
  proposedPattern     String?          @map("proposed_pattern")
  proposedMatchConfig Json?            @map("proposed_match_config")
  proposedAction      Action           @map("proposed_action")
  proposedSeverity    Severity         @default(medium) @map("proposed_severity")
  matchCount          Int              @default(0) @map("match_count") // matches retroactivos sobre interactions
  examples            Json             @default("[]") // [{traceId, promptRedacted, createdAt}]
  sourceHint          String?          @map("source_hint") // "google_workspace" | null — distingue origen en la UI
  status              SuggestionStatus @default(pending)
  rejectReason        String?          @map("reject_reason")
  acceptedPolicyId    String?          @map("accepted_policy_id") @db.Uuid
  createdAt           DateTime         @default(now()) @map("created_at")
  decidedAt           DateTime?        @map("decided_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, status, createdAt(sort: Desc)])
  @@map("rule_suggestions")
}
