# =============================================================
# Tranquera interceptor — environment variables
# Copy to .env and fill in.
# =============================================================

# Postgres shared with web/ (see root docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://team22:team22@localhost:5432/team22

# Upstream Anthropic API for Claude Code passthrough.
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# NL judge provider (Layer 3). If JUDGE_API_KEY is empty, NL is disabled and
# the proxy behaves like v0.1 (regex + passthrough). Supported providers:
# anthropic | opencode-go | openai | gemini
JUDGE_PROVIDER=opencode-go
JUDGE_BASE_URL=https://opencode.ai/zen/go/v1
JUDGE_MODEL=qwen3.6-plus
JUDGE_API_KEY=

# Legacy Anthropic judge config. Still supported as fallback when JUDGE_API_KEY
# is empty and JUDGE_PROVIDER is unset/anthropic.
ANTHROPIC_JUDGE_API_KEY=

# Optional Specialized Local Judge (spec 17). Disabled by default; when enabled,
# the interceptor calls this service before falling back to the external judge.
LOCAL_JUDGE_ENABLED=false
LOCAL_JUDGE_BASE_URL=http://localhost:8088
LOCAL_JUDGE_TIMEOUT_MS=800
LOCAL_JUDGE_CONFIDENCE_THRESHOLD=0.75
LOCAL_JUDGE_HIGH_RISK_THRESHOLD=0.90
LOCAL_JUDGE_MODEL_VERSION=qwen3-4b-localjudge-prompt-v1
LOCAL_JUDGE_FAIL_OPEN=true

# Single-tenant org for the hack (matches web/.env.local DEMO_ORG_ID).
DEFAULT_ORG_ID=demo

# Server bind.
HOST=0.0.0.0
PORT=8080
